# ─────────────────────────────────────────────────────────────
# OneCRM — environment overrides for Docker Compose
# Copy to `.env` and edit if the defaults collide with another
# service on the host:  cp .env.example .env
# ─────────────────────────────────────────────────────────────

# Host port for the app (React SPA + /api proxy). This is what you
# point the host Nginx vhost / browser at.
WEB_PORT=3000

# Host port for direct access to the Bun API server.
SERVER_PORT=3001
